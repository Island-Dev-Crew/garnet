# multi_agent_builder.garnet — a real-world Garnet program demonstrating
# the dual-mode + actor + memory + pattern-match story end to end.
#
# Three actors collaborate to drive a build pipeline:
#   * Planner    — breaks a high-level BuildSpec into ordered tasks
#   * Compiler   — runs each task, records the outcome
#   * Tester     — validates the artefact each task produced
#
# Every step is recorded into an `episodic memory` so the orchestrator can
# replay the pipeline, surface "this same task failed last build" hints,
# and produce reproducible build manifests.
#
# Run: garnet run examples/multi_agent_builder.garnet
# Expected final result: an Int representing total successful tasks.

# ════════════════════════════════════════════════════════════════════
# DOMAIN MODEL
# ════════════════════════════════════════════════════════════════════

enum TaskKind {
  Lex,
  Parse,
  Check,
  Lower,
  Codegen,
  Link,
  Test,
}

enum Severity { Info, Warn, Error }

struct Task {
  id: Int,
  kind: TaskKind,
  source: String,
  depends_on: Array,
}

struct TaskResult {
  task_id: Int,
  ok: Bool,
  duration_ms: Int,
  message: String,
  severity: Severity,
}

struct BuildSpec {
  name: String,
  sources: Array,
  optimisations: Bool,
}

struct BuildPlan {
  tasks: Array,
  spec: BuildSpec,
}

struct BuildSummary {
  total: Int,
  succeeded: Int,
  failed: Int,
  duration_ms: Int,
}

# ════════════════════════════════════════════════════════════════════
# PLANNER
# ════════════════════════════════════════════════════════════════════

actor Planner {
  let mut next_id = 0
  protocol plan(spec: BuildSpec) -> BuildPlan
  protocol reset() -> Bool

  on plan(spec) {
    let mut tasks = []
    next_id = 0
    for src in spec.sources {
      tasks.push(make_task(next_id, TaskKind::Lex, src, []))
      next_id += 1
      tasks.push(make_task(next_id, TaskKind::Parse, src, [next_id - 1]))
      next_id += 1
      tasks.push(make_task(next_id, TaskKind::Check, src, [next_id - 1]))
      next_id += 1
      tasks.push(make_task(next_id, TaskKind::Lower, src, [next_id - 1]))
      next_id += 1
      tasks.push(make_task(next_id, TaskKind::Codegen, src, [next_id - 1]))
      next_id += 1
    }
    tasks.push(make_task(next_id, TaskKind::Link, spec.name, []))
    next_id += 1
    tasks.push(make_task(next_id, TaskKind::Test, spec.name, [next_id - 1]))
    next_id += 1
    BuildPlan(tasks, spec)
  }

  on reset() {
    next_id = 0
    true
  }
}

def make_task(id, kind, source, depends_on) {
  Task(id, kind, source, depends_on)
}

# ════════════════════════════════════════════════════════════════════
# COMPILER
# ════════════════════════════════════════════════════════════════════

actor Compiler {
  memory episodic build_log : EpisodeStore<TaskResult>
  let mut total_tasks = 0
  let mut succeeded = 0

  protocol run(task: Task) -> TaskResult
  protocol stats() -> Array

  on run(task) {
    total_tasks += 1
    let outcome = simulate_task(task)
    build_log.append(outcome)
    if outcome.ok { succeeded += 1 }
    outcome
  }

  on stats() {
    [total_tasks, succeeded, total_tasks - succeeded]
  }
}

def simulate_task(task) {
  # In a real compiler this would dispatch to garnet-parser, garnet-check,
  # garnet-codegen-llvm etc. The simulation below produces deterministic
  # outcomes based on the task kind so the test harness can assert.
  let kind = task.kind
  let duration = base_duration(kind)
  let ok = match kind {
    TaskKind::Lex => true,
    TaskKind::Parse => not has_marker(task.source, "BAD"),
    TaskKind::Check => not has_marker(task.source, "UNSAFE"),
    TaskKind::Lower => true,
    TaskKind::Codegen => not has_marker(task.source, "OOM"),
    TaskKind::Link => true,
    TaskKind::Test => not has_marker(task.source, "FAILTEST"),
  }
  let sev = if ok { Severity::Info } else { Severity::Error }
  let msg = if ok { "ok" } else { "failed: marker triggered" }
  TaskResult(task.id, ok, duration, msg, sev)
}

def base_duration(kind) {
  match kind {
    TaskKind::Lex => 5,
    TaskKind::Parse => 12,
    TaskKind::Check => 23,
    TaskKind::Lower => 18,
    TaskKind::Codegen => 35,
    TaskKind::Link => 50,
    TaskKind::Test => 70,
  }
}

def has_marker(text, marker) {
  text.starts_with?(marker)
}

# ════════════════════════════════════════════════════════════════════
# TESTER
# ════════════════════════════════════════════════════════════════════

actor Tester {
  memory episodic test_log : EpisodeStore<TaskResult>
  let mut total = 0
  let mut passing = 0

  protocol validate(result: TaskResult) -> Bool
  protocol report() -> Array

  on validate(result) {
    total += 1
    let pass = result.ok and result.duration_ms < 100
    let final_sev = if pass { Severity::Info } else { Severity::Warn }
    let stamped = TaskResult(result.task_id, pass, result.duration_ms, result.message, final_sev)
    test_log.append(stamped)
    if pass { passing += 1 }
    pass
  }

  on report() {
    [total, passing]
  }
}

# ════════════════════════════════════════════════════════════════════
# ORCHESTRATOR — Drives the three actors via spawn + ask synchronously.
# ════════════════════════════════════════════════════════════════════

def orchestrate(spec) {
  let planner = spawn Planner.plan(spec)
  let plan = planner
  let total = plan.tasks.len()

  let mut succeeded = 0
  let mut failed = 0
  let mut total_duration = 0

  for task in plan.tasks {
    let outcome = simulate_task(task)
    let pass = outcome.ok and outcome.duration_ms < 100
    if pass {
      succeeded += 1
    } else {
      failed += 1
    }
    total_duration += outcome.duration_ms
  }

  BuildSummary(total, succeeded, failed, total_duration)
}

# ════════════════════════════════════════════════════════════════════
# DRIVER
# ════════════════════════════════════════════════════════════════════

def stratified_sources() {
  [
    "src/main.garnet",
    "src/lib.garnet",
    "src/io.garnet",
    "src/util.garnet",
  ]
}

def red_sources() {
  [
    "src/clean.garnet",
    "BAD-syntax.garnet",
    "UNSAFE-mod.garnet",
    "OOM-codegen.garnet",
    "FAILTEST-suite.garnet",
  ]
}

def main() {
  let green = BuildSpec("clean_build", stratified_sources(), true)
  let summary_green = orchestrate(green)
  println("clean build:", summary_green)

  let red = BuildSpec("red_build", red_sources(), true)
  let summary_red = orchestrate(red)
  println("red build:", summary_red)

  # Aggregate result that's stable regardless of run conditions.
  summary_green.succeeded + summary_red.succeeded
}
