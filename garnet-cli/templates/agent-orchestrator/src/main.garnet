# {{name}} - a runnable Researcher / Synthesizer / Reviewer orchestrator.
#
# This template keeps the first-run path executable on the current v0.3
# interpreter. The role names and memory-kind vocabulary match MVP 6, but actor
# spawning is deliberately left to the roadmap until `garnet run` bridges the
# actor runtime end-to-end.

def researcher(seed) {
  seed + 2
}

def synthesizer(facts) {
  facts * 3
}

def reviewer(score) {
  if score >= 12 {
    score + 1
  } else {
    score
  }
}

def orchestrate(seed) {
  let facts = researcher(seed)
  let draft = synthesizer(facts)
  reviewer(draft)
}

@caps()
def main() {
  println("starting {{name}}: Researcher / Synthesizer / Reviewer")
  let accepted = orchestrate(3)
  println("accepted decision score:", accepted)
  accepted
}
