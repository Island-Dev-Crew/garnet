# Starter test for {{name}}.
#
# Garnet's test harness (Rung 7 — shipping v3.5) recognizes every top-
# level function whose name starts with `test_` as a test. Assertions
# use the prelude's `assert` and `assert_eq` primitives (no caps
# required — pure compute).

def test_arithmetic() {
  assert_eq(2 + 2, 4)
  assert_eq(10 - 3, 7)
}

def test_string_interpolation() {
  let name = "garnet"
  let greeting = "hello, #{name}!"
  assert_eq(greeting, "hello, garnet!")
}
